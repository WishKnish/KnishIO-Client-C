# clang-tidy lint gate for the KnishIO C SDK (cycle 115; the C analog of the C++ SDK gate).
#
# Pragmatic baseline: enable the high-value real-bug families (bugprone, performance) and
# leave the style firehose OFF (readability/modernize/cert/misc/llvm — magic-numbers, casts,
# naming) — mirrors the Rust clippy::all-not-pedantic (c111) + C++ clang-tidy (c114) philosophy.
# Read-only gate (no --fix) → cannot move the frozen molecular hashes. Scope: compiled
# first-party src/ (KNISHIO_SOURCES minus vendored mlkem-native), driven by the CMake `lint`
# target; vendored/external excluded by the file list + the header filters below.
Checks: >
  -*,
  bugprone-*,
  performance-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -bugprone-switch-missing-default-case,
  -bugprone-reserved-identifier,
  -bugprone-empty-catch,
  -bugprone-multi-level-implicit-pointer-conversion,
  -bugprone-assignment-in-if-condition,
  -bugprone-unchecked-string-to-number-conversion,
  -bugprone-implicit-widening-of-multiplication-result,
  -bugprone-branch-clone
# (C-idiom relaxations: multi-level-implicit-pointer-conversion floods on void**/generic
#  pointers; assignment-in-if-condition flags the standard `if ((e = f()) != SUCCESS) goto cleanup`
#  error-handling idiom; unchecked-string-to-number flags atoi/atoll/sscanf on the SDK's OWN
#  trusted serialized values + hex; implicit-widening flags bounded `idx*sizeof`/constant multiplies
#  [the real overflow guard is knishio_safe_mul_size_t]; branch-clone flags intentional dup enum cases.)
WarningsAsErrors: '*'
HeaderFilterRegex: '.*/src/.*'
ExcludeHeaderFilterRegex: '.*/(external|third_party)/.*'
FormatStyle: none
